# Copy to `.env` in the project root and adjust values.
# Usage: docker compose --env-file .env up --build

# --- MySQL (must match DATABASE_URL password) ---
MYSQL_ROOT_PASSWORD=chatty_root
MYSQL_DATABASE=chatty

# Prisma / Nest (hostname `mysql` is the Compose service name)
DATABASE_URL=mysql://root:chatty_root@mysql:3306/chatty

# --- Backend ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Browser-facing origin (must match how you open the app). Used for CORS and baked into the frontend build.
PUBLIC_ORIGIN=http://localhost:8080
CORS_ORIGIN=http://localhost:8080


# Ollama on the Mac host (Docker Desktop provides host.docker.internal).
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=qwen2.5:1.5b
OLLAMA_EVAL_MODEL=qwen2.5:1.5b

# FCM (optional). Either set JSON inline or mount a file and set GOOGLE_APPLICATION_CREDENTIALS inside the container.
FIREBASE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=

# --- Frontend build args (optional; same as local Vite names) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FCM_VAPID_KEY=

# Published HTTP port on the host (nginx).
HTTP_PORT=8080
